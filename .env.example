# ──────────────────────────────────────────────────
# MarketFlow AI — Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ──────────────────────────────────────────────────

# GEMINI_API_KEY (Required)
# Your Google Gemini API key from https://aistudio.google.com/apikey
# This key is used SERVER-SIDE ONLY — never exposed to the client.
GEMINI_API_KEY="your_gemini_api_key_here"

# PORT (Optional, default: 3000)
# The port the Express server will listen on.
# PORT=3000

# NODE_ENV (Optional)
# Set to "production" for production builds.
# NODE_ENV=development
